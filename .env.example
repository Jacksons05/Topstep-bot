# ── Database (required on Railway; omit for stateless local runs) ─────────
# Railway injects this automatically when you add a Postgres service.
DATABASE_URL=

# ── Engine loop ────────────────────────────────────────────
SCAN_INTERVAL_SEC=60          # seconds between cycles (calm regime)
FAST_INTERVAL_SEC=15          # cadence when a circuit breaker trips
WATCHLIST=AAPL,MSFT,NVDA,SPY,QQQ,TSLA,AMZN,META
REGIME_SYMBOL=SPY             # index used for regime + circuit breaker

# ── Asset classes ──────────────────────────────────────────
TRADE_EQUITIES=true
TRADE_OPTIONS=false           # needs an OPTIONS_SOURCE with dealer-positioning data

# ── Confluence thresholds ─────────────────────────────────
CONFIDENCE_THRESHOLD=0.60     # quant + qualitative must agree AND clear this
MIN_CONFIDENCE=medium         # low|medium|high
SMA_FAST=20
SMA_SLOW=50
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
ATR_PERIOD=14

# ── News / sentiment (multi-source, aggregated) ───────────
NEWS_ENABLED=true
# Comma list, pulled in parallel + merged round-robin (deduped) per symbol.
# Each source degrades to empty without its key, so extra sources are free.
#   google  free RSS baseline (no key)
#   alpaca  Benzinga headlines via existing Alpaca creds
#   finnhub company news + summaries (FINNHUB_API_KEY)
#   sec     SEC EDGAR 8-K material-event filings (no key, needs SEC_USER_AGENT)
#   polygon ticker news w/ sentiment label (POLYGON_API_KEY)
NEWS_SOURCES=google,alpaca,finnhub,sec
NEWS_SOURCE=google            # legacy single-source fallback if NEWS_SOURCES unset
POLYGON_API_KEY=
FINNHUB_API_KEY=              # also powers the earnings/econ event blackout
NEWS_PER_SYMBOL=6             # per-source pull cap
NEWS_MAX_HEADLINES=10         # aggregate cap fed to the Analyst
NEWS_LOOKBACK_HOURS=48
# SEC EDGAR — fair-access policy REQUIRES a descriptive UA with a contact email.
SEC_USER_AGENT=jarvis-stock jackson.g.sheehan@gmail.com
SEC_FORM_TYPES=8-K            # filing types to surface as headlines
SEC_LOOKBACK_DAYS=21          # filings stay material longer than a headline

# ── Macro regime (FRED, free key) ─────────────────────────
MACRO_ENABLED=true
FRED_API_KEY=                 # VIX/10y/fed-funds regime line for the Analyst

# ── Options / dealer-positioning (GEX stack) ──────────────
OPTIONS_SOURCE=none           # none|chain|flashalpha
FLASHALPHA_API_KEY=
WALL_PROXIMITY_PCT=0.5        # treat a gamma wall as in-play within this % of spot

# ── LLM (agent brains) ────────────────────────────────────
LLM_ENABLED=true
LLM_BACKEND=anthropic         # anthropic | ollama
ANTHROPIC_API_KEY=your_key_here
LLM_MODEL=claude-sonnet-4-6   # fast model for per-symbol signals
LLM_MODEL_DEEP=claude-opus-4-8  # high-reasoning model for deep analysis/debate
LLM_TEMPERATURE=0.0           # 0 = deterministic structured JSON
LLM_MAX_SYMBOLS_PER_CYCLE=20
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# ── Multi-agent team toggles ──────────────────────────────
AGENT_ANALYST=true
AGENT_RESEARCH_DEBATE=true    # bull vs bear debate
AGENT_PORTFOLIO=true          # conviction-weighted allocation
AGENT_RISK_MANAGER=true       # structural veto (walls / gamma regime)

# ── Trading / sizing ──────────────────────────────────────
TRADING_MODE=paper            # paper | live  (LIVE MOVES REAL MONEY)
BANKROLL_USD=50000            # Topstep $50K account start (equity base for sizing)
MAX_POSITION_PCT=0.05         # max 5% of bankroll per name
MAX_CONCURRENT=12
MIN_EXECUTABLE_SIZE_USD=100

# ── Exits: ATR brackets + hard floors ─────────────────────
ATR_STOP_MULT=2.0             # stop = entry - mult*ATR
ATR_TARGET_MULT=3.0           # target = entry + mult*ATR
TAKE_PROFIT_PCT=0.0           # override ATR target with a flat % (0 = off)
STOP_LOSS_PCT=0.08            # hard stop floor regardless of ATR

# ── Safety layers ─────────────────────────────────────────
DAILY_DRAWDOWN_PCT=0.05       # halt new entries once down this much for the day
CB_YELLOW_PCT=0.05            # regime move >5% -> halve sizes
CB_RED_PCT=0.10               # regime move >10% -> halt entries
TRADE_COOLDOWN_SEC=900        # falling-knife: per-symbol re-entry cooldown
KILL_SWITCH_FILE=KILL_SWITCH  # create this file to halt instantly
CRAMER_MODE=true              # run an inverse shadow book to validate signals

# ── Broker ────────────────────────────────────────────────
BROKER=alpaca                 # alpaca | ibkr | sim
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_URL=https://api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
DATA_FEED=iex                 # iex (free) | sip (paid)
# IBKR (only when BROKER=ibkr)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Notifications (optional) ──────────────────────────────
DISCORD_WEBHOOK=
LOG_FILE=signals.log

# ── Topstep futures via ProjectX / TopstepX ───────────────
# ProjectX is Topstep's REST + SignalR gateway. Set username + API key (TopstepX
# → Settings → API Keys) to execute futures live; blank → bot runs the agentic
# pipeline on the Sim/paper broker. The order-flow gate + Topstep risk are unchanged.
TOPSTEP_MODE_ENABLED=true
PROJECTX_USERNAME=            # TopstepX login / username
PROJECTX_API_KEY=            # API key from TopstepX → Settings → API Keys
PROJECTX_API_BASE=https://api.topstepx.com
PROJECTX_RTC_BASE=https://rtc.topstepx.com
PROJECTX_ACCOUNT_NAME=       # blank → first tradable account
PROJECTX_LIVE=false          # false = sim/eval data sub; true = funded/live
FUTURES_SYMBOLS=ES,NQ,MES,MNQ

# ── Topstep $50K funded-account rules (No-Activation-Fee + Responsible Trading) ──
# Defaults are the official Topstep $50K spec (2026). For other sizes override all:
#   $100K → SIZE=100000 MLL=3000 DLL=2000 CONTRACTS=10 TARGET=6000
#   $150K → SIZE=150000 MLL=4500 DLL=3000 CONTRACTS=15 TARGET=9000
TOPSTEP_ACCOUNT_SIZE=50000        # starting balance
TOPSTEP_TRAILING_MLL=2000         # trailing Max Loss Limit ($) — the one HARD fail rule
TOPSTEP_PROFIT_TARGET=3000        # Combine profit objective
TOPSTEP_MAX_CONTRACTS=5           # account-wide max open minis (50 micros @ 10:1)
TOPSTEP_MICRO_RATIO=10            # micros per 1 mini toward the limit
TOPSTEP_RESPONSIBLE_TRADING=true  # Responsible Trading Advantage → enables the Daily Loss Limit
TOPSTEP_DAILY_LOSS_LIMIT=1000     # DLL ($) — deactivates the day (not the account)
TOPSTEP_CONSISTENCY_PCT=0.50      # best day ≤ this fraction of profit target ($1,500/day)
TOPSTEP_SCALP_GUARD_ENABLED=false # Topstep does NOT ban scalping
TOPSTEP_FLATTEN_TIME=16:08        # flatten all by this ET (before the 16:10 futures close)
TOPSTEP_ECON_BLACKOUT_MIN=5       # no new entries within N min of a major macro release

# ── Order-flow confirmation gate (live ProjectX quote + trade + L2 feed) ──
# Applied only when the live feed has data for the symbol; fails open otherwise.
# Needs signalrcore in the venv for the SignalR market hub (pip install signalrcore).
ORDERFLOW_GATE_ENABLED=true
OF_OBI_THRESHOLD=0.85          # |OBI| required in trade direction at a wall (→ ±1.0)
OF_WHALE_Z=3.5                # MAD modified z-score to flag an institutional block
OF_WHALE_NOTIONAL_USD=1000000  # min $/contract/second for a whale flag
OF_FOOTPRINT_RATIO=10         # aggressive-side dominance for absorption
OF_WINDOW_SEC=120             # rolling window for z-score / CVD divergence
OF_DEPTH_LEVELS=5             # L2 ladder levels summed for depth OBI (needs GatewayDepth)
